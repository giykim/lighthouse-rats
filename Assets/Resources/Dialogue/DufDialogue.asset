  m_Script: {fileID: 11500000, guid: 4d691644aa162fb40b8d6942da9d145c, type: 3}
  m_Name: DufDialogue
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  entries:
  - requiredEvents:
    - Test
    phases: []
  - requiredEvents: []
    phases:
    - lines:
      - Hey, I'm Duf!
      - I used to love tinkering with things, but...
      - My brother Ham's been missing and I'm worried sick.
    - lines:
      - Ham and I used to be called the engineers of the rat society.
      - But he recently just poofed and vanished...
      - I don't even know where he would have gone off to, given he's become very
        lazy.
    - lines:
      - Ham and I used to love tinkering with gears when we were young...
